        <mxCell id="eddy_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#EF9A9A;opacity=50;" value="" vertex="1">
          <mxGeometry height="650" width="250" x="1310" y="460" as="geometry" />
        </mxCell>
        <mxCell id="eddy_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=10;" value="EDDY CURRENT" vertex="1">
          <mxGeometry height="20" width="120" x="1370" y="462" as="geometry" />
        </mxCell>
        <mxCell id="n_m" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;m = ω · 10⁻⁷ / R_s&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;IEC 60287-1-1:2023 Section 5.3.7.1&lt;/font&gt;" vertex="1">
          <mxGeometry height="45" width="220" x="1325" y="490" as="geometry" />
        </mxCell>
        <mxCell id="e_x_m" edge="1" parent="1" source="n_X" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_m">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_l0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;λ₀ — Base eddy coupling (trefoil)&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;λ₀ = 3 · [m²/(1+m²)] · (d/(2s))²&lt;br&gt;C_C0 = 3 for trefoil&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="220" x="1325" y="555" as="geometry" />
        </mxCell>
        <mxCell id="e_m_l0" edge="1" parent="1" source="n_m" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_l0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_delta" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;Δ₁, Δ₂ — Correction terms&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Δ₁ = (1.14·m^2.45 + 0.33) · (d/2s)^(0.92m+1.66)&lt;br&gt;Δ₂ = 0 (trefoil formation)&lt;/font&gt;" vertex="1">
          <mxGeometry height="65" width="220" x="1325" y="635" as="geometry" />
        </mxCell>
        <mxCell id="e_l0_d" edge="1" parent="1" source="n_l0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_delta">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_beta" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;β₁, C_gs, thickness term&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;β₁ = √(4πω / (ρ_s · 10⁷))&lt;br&gt;C_gs = 1 + (t_s/D_s)^1.74 · (β₁·D_s·10⁻³ - 1.6)&lt;br&gt;thickness = (β₁·t_s)⁴ / (12·10¹²)&lt;/font&gt;" vertex="1">
          <mxGeometry height="75" width="220" x="1325" y="720" as="geometry" />
        </mxCell>
        <mxCell id="e_d_beta" edge="1" parent="1" source="n_delta" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_beta">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_l1pp_raw" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;λ₁&#39;&#39; (raw) — IEC 60287-1-1 Sec 5.3.7.1&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;λ₁&#39;&#39; = (R_s/R_ac) · [C_gs · λ₀ · (1+Δ₁+Δ₂) + thickness]&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="220" x="1325" y="820" as="geometry" />
        </mxCell>
        <mxCell id="e_beta_l1pp" edge="1" parent="1" source="n_beta" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_l1pp_raw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_F_flag" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;fontSize=9;" value="apply_F ?&lt;br&gt;&lt;font size=&quot;1&quot;&gt;(circ AND eddy AND&lt;br&gt;F_flag all True)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="180" x="1345" y="900" as="geometry" />
