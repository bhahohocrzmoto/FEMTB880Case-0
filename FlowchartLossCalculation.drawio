        <mxCell id="n_prox_flag" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;" value="include proximity&amp;nbsp;effect ?" vertex="1">
          <mxGeometry height="75" width="170" x="225" y="890" as="geometry" />
        </mxCell>
        <mxCell id="e_yp_flag" edge="1" parent="1" source="n_yp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_prox_flag">
