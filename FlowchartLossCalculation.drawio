        <mxCell id="n_F_calc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;F factor — IEC 60287-1-1:2023 Section 5.3.6&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;M = R_s/X (trefoil: M=N)&lt;br&gt;F = (4M⁴ + (2M)²) / (4(M²+1)²)&lt;br&gt;λ₁&#39;&#39; = λ₁&#39;&#39; · F&lt;br&gt;(TB 880 GP 31: apply to all conductors)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="220" x="1325" y="1010" as="geometry" />
