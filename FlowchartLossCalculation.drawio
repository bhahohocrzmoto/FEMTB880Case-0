        <mxCell id="lbl_true1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=9;fontColor=#009900;" value="True" vertex="1">
          <mxGeometry height="15" width="40" x="310" y="615" as="geometry" />
        </mxCell>
        <mxCell id="n_xp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" value="&lt;b&gt;x&lt;sub&gt;p&lt;/sub&gt;² — IEC 60287-1-1:2023 Section 5.1.5.1&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;x&lt;sub&gt;p&lt;/sub&gt;² = 8π f · 10⁻⁷ · k&lt;sub&gt;p&lt;/sub&gt; / R&apos;(θ)&lt;br&gt;k&lt;sub&gt;p&lt;/sub&gt; = 1.0 (IEC 60287-1-1:2023 Table 2)&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="460" x="80" y="645" as="geometry" />
        </mxCell>
        <mxCell id="e_skin_xp" edge="1" parent="1" source="n_skin_flag" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_xp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_yp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" value="&lt;b&gt;y&lt;sub&gt;p&lt;/sub&gt; — Proximity effect factor — IEC 60287-1-1:2023 Section 5.1.5.1&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;g = x&lt;sub&gt;p&lt;/sub&gt;⁴ / (192 + 0.8·x&lt;sub&gt;p&lt;/sub&gt;⁴)&lt;br&gt;y&lt;sub&gt;p&lt;/sub&gt; = g · (d&lt;sub&gt;c&lt;/sub&gt;/s)² · [0.312·(d&lt;sub&gt;c&lt;/sub&gt;/s)² + 1.18 / (g + 0.27)]&lt;br&gt;s = d&lt;sub&gt;oversheath&lt;/sub&gt;, d&lt;sub&gt;c&lt;/sub&gt; = 30.3 mm&lt;/font&gt;" vertex="1">
          <mxGeometry height="75" width="460" x="80" y="720" as="geometry" />
        </mxCell>
        <mxCell id="e_xp_yp" edge="1" parent="1" source="n_xp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_yp">
