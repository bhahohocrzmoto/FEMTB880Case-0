        <mxCell id="n_delta" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;Δ₁, Δ₂ — Correction terms&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Δ₁ = (1.14·m&lt;sup&gt;2.45 &lt;/sup&gt;+ 0.33) · (d/2s)&lt;sup&gt;(0.92m+1.66)&lt;/sup&gt;&lt;br&gt;Δ₂ = 0 (trefoil formation)&lt;/font&gt;" vertex="1">
