        <mxCell id="n_wd_out" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;fontColor=#FFFFFF;fontStyle=1;" value="&lt;b&gt;W&lt;sub&gt;d&lt;/sub&gt; [W/m]&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Dielectric loss (voltage dependent, current&amp;amp;temperature independent)&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="250" x="675" y="730" as="geometry" />
        </mxCell>
        <mxCell id="e_diel_out" edge="1" parent="1" source="n_diel_flag" style="rounded=0;" target="n_wd_out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sheath_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;opacity=40;" value="" vertex="1">
          <mxGeometry height="1130" width="650" x="1030" y="270" as="geometry" />
        </mxCell>
        <mxCell id="sheath_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=12;" value="SHEATH LOSSES — W&lt;sub&gt;s&lt;/sub&gt; = λ₁ · W&lt;sub&gt;c&lt;/sub&gt;" vertex="1">
          <mxGeometry height="25" width="350" x="1161" y="275" as="geometry" />
        </mxCell>
        <mxCell id="n_rs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;R&lt;sub&gt;s&lt;/sub&gt;(θ) — Sheath DC resistance&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;R&lt;sub&gt;s&lt;/sub&gt; = ρ&lt;sub&gt;screen&lt;/sub&gt;(20°C) · [1 + α&lt;sub&gt;screen&lt;/sub&gt; · (T&lt;sub&gt;screen&lt;/sub&gt; - 20)] / A&lt;/font&gt;&lt;span style=&quot;font-size: 8.33333px;&quot;&gt;screen&lt;/span&gt;&lt;font size=&quot;1&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;font-size: x-small;&quot;&gt;ρ&lt;/span&gt;&lt;sub&gt;screen&lt;/sub&gt;&lt;font size=&quot;1&quot;&gt;(20°C) = 2.84×10⁻⁸ Ωm (IEC 60287-1-1:2023 Table 1, aluminium)&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;font-size: x-small;&quot;&gt;α&lt;/span&gt;&lt;sub&gt;screen&lt;/sub&gt;&lt;span style=&quot;font-size: x-small;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;font size=&quot;1&quot;&gt;= 4.03×10⁻³ K⁻¹&lt;br&gt;&lt;/font&gt;&lt;font size=&quot;1&quot;&gt;A&lt;/font&gt;&lt;span style=&quot;font-size: 8.33333px;&quot;&gt;&lt;sub&gt;screen&lt;/sub&gt;&lt;/span&gt;&lt;font size=&quot;1&quot;&gt;= A_screen_elec (analytical) or A_screen_FE_model (fem)&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="520" x="1120" y="315" as="geometry" />
        </mxCell>
        <mxCell id="n_X" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;X — Sheath reactance — IEC 60287-1-1:2023 Section 5.3.2&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;X = 2ω · 10⁻⁷ · ln(2s / d_screen_mean)&lt;br&gt;s = d_oversheath = 75.5 mm (touching trefoil)&lt;br&gt;d_screen_mean = 67.7 mm&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: x-small;&quot;&gt;Note: X is used for λ₁′ and the F factor —&amp;nbsp;&lt;/span&gt;&lt;b style=&quot;font-size: x-small;&quot;&gt;not&lt;/b&gt;&lt;span style=&quot;font-size: x-small;&quot;&gt;&amp;nbsp;for computing m (eddy)&lt;/span&gt;&lt;font size=&quot;1&quot;&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="75" width="480" x="1140" y="430" as="geometry" />
        </mxCell>
