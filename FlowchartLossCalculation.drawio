        <mxCell id="lbl_true1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=9;fontColor=#009900;" value="True" vertex="1">
          <mxGeometry height="15" width="40" x="310" y="685" as="geometry" />
