        <mxCell id="sheath_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=12;" value="SHEATH LOSSES — W_s = λ₁ · W_c" vertex="1">
          <mxGeometry height="25" width="350" x="1081" y="205" as="geometry" />
        </mxCell>
        <mxCell id="n_rs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;R_s(θ) — Sheath DC resistance&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;R_s = ρ_screen(20°C) · [1 + α_screen · (T_screen - 20)] / A_screen&lt;br&gt;ρ_screen(20°C) = 2.84×10⁻⁸ Ωm (IEC 60287-1-1 Table 1, aluminium)&lt;br&gt;α_screen = 4.03×10⁻³ K⁻¹&lt;br&gt;A_screen = A_screen_elec (analytical) or A_screen_FE_model (fem)&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="520" x="1040" y="245" as="geometry" />
        </mxCell>
        <mxCell id="n_X" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;X — Sheath reactance — IEC 60287-1-1:2023 Section 5.3.2&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;X = 2ω · 10⁻⁷ · ln(2s / d_screen_mean)&lt;br&gt;s = d_oversheath = 75.5 mm (touching trefoil)&lt;br&gt;d_screen_mean = 67.7 mm&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="480" x="1060" y="365" as="geometry" />
        </mxCell>
        <mxCell id="e_rs_x" edge="1" parent="1" source="n_rs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_X">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="circ_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#EF9A9A;opacity=50;" value="" vertex="1">
          <mxGeometry height="250" width="240" x="1040" y="460" as="geometry" />
        </mxCell>
        <mxCell id="circ_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=10;" value="CIRCULATING" vertex="1">
          <mxGeometry height="20" width="120" x="1095" y="462" as="geometry" />
        </mxCell>
        <mxCell id="n_l1p" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;λ₁&#39; — IEC 60287-1-1:2023 Section 5.3.2&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;λ₁&#39; = (R_s/R_ac) · 1/(1 + (R_s/X)²)&lt;br&gt;Touching trefoil formula&lt;/font&gt;" vertex="1">
          <mxGeometry height="65" width="210" x="1055" y="490" as="geometry" />
        </mxCell>
        <mxCell id="e_x_l1p" edge="1" parent="1" source="n_X" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_l1p">
