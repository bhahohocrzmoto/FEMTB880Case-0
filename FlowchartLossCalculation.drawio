        <mxCell id="n_ys_zero" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="y&lt;sub&gt;s&lt;/sub&gt; = 0" vertex="1">
