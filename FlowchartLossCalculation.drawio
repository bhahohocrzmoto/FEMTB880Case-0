        </mxCell>
        <mxCell id="n_wd_zero" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="W&lt;sub&gt;d&lt;/sub&gt; = 0" vertex="1">
          <mxGeometry height="28" width="70" x="625" y="640" as="geometry" />
        </mxCell>
        <mxCell id="e_diel_zero" edge="1" parent="1" source="n_diel_flag" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_wd_zero">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl_false3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=9;fontColor=#CC0000;" value="False" vertex="1">
          <mxGeometry height="15" width="30" x="700" y="625" as="geometry" />
        </mxCell>
