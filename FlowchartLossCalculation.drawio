        <mxCell id="n_circ_flag" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;fontSize=9;" value="include_sheath&lt;br&gt;_circulating&lt;br&gt;_losses ?" vertex="1">
          <mxGeometry height="80" width="150" x="1080" y="580" as="geometry" />
