        <mxCell id="cond_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;opacity=40;" value="" vertex="1">
          <mxGeometry height="900" width="540" x="40" y="270" as="geometry" />
        </mxCell>
        <mxCell id="cond_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=12;" value="CONDUCTOR LOSSES — W&lt;sub&gt;c&lt;/sub&gt; = I² · R&lt;sub&gt;ac&lt;/sub&gt;" vertex="1">
          <mxGeometry height="25" width="350" x="84" y="275" as="geometry" />
        </mxCell>
        <mxCell id="n_rdc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" value="&lt;b&gt;def Rdc_at_temp(T_cond_C) — IEC 60287-1-1:2023 Section 5.1.2&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;R&lt;sub&gt;dc&lt;/sub&gt; = R&lt;sub&gt;dc&lt;/sub&gt;(20°C) · [1 + α₂₀ · (T&lt;sub&gt;core&lt;/sub&gt; - 20)]&lt;br&gt;R₀ = 2.83×10⁻⁵ Ω/m (IEC 60228, TB 880 primary input)&lt;br&gt;α₂₀ = 3.93×10⁻³ K⁻¹ (IEC 60287-1-1:2023 Table 1, copper)&lt;/font&gt;" vertex="1">
          <mxGeometry height="75" width="460" x="80" y="315" as="geometry" />
        </mxCell>
        <mxCell id="n_xs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" value="&lt;b&gt;x&lt;sub&gt;s&lt;/sub&gt;² — IEC 60287-1-1:2023 Section 5.1.3&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;x&lt;sub&gt;s&lt;/sub&gt;² = 8π f · 10⁻⁷ · k&lt;sub&gt;s&lt;/sub&gt; / R&#39;(θ)&lt;br&gt;k&lt;sub&gt;s&lt;/sub&gt; = 1.0 (IEC 60287-1-1:2023 Table 2, round stranded + extruded insulation)&lt;/font&gt;" vertex="1">
          <mxGeometry height="65" width="460" x="80" y="415" as="geometry" />
        </mxCell>
        <mxCell id="e_rdc_xs" edge="1" parent="1" source="n_rdc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_xs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_ys" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" value="&lt;b&gt;y&lt;sub&gt;s&lt;/sub&gt; — Skin effect factor — IEC 60287-1-1:2023 Section 5.1.3&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;x&lt;sub&gt;s&lt;/sub&gt; ≤ 2.8: y&lt;sub&gt;s&lt;/sub&gt; = x&lt;sub&gt;s&lt;/sub&gt;⁴ / (192 + 0.8·x&lt;sub&gt;s&lt;/sub&gt;⁴)&lt;br&gt;2.8 &amp;lt; x&lt;sub&gt;s&lt;/sub&gt; ≤ 3.8: y&lt;sub&gt;s&lt;/sub&gt; = -0.136 - 0.0177·x&lt;sub&gt;s&lt;/sub&gt; + 0.0563·x&lt;sub&gt;s&lt;/sub&gt;²&lt;br&gt;x&lt;sub&gt;s&lt;/sub&gt; &amp;gt; 3.8: y&lt;sub&gt;s&lt;/sub&gt; = 0.354·x&lt;sub&gt;s&lt;/sub&gt; - 0.733&lt;/font&gt;" vertex="1">
          <mxGeometry height="75" width="460" x="80" y="505" as="geometry" />
        </mxCell>
        <mxCell id="e_xs_ys" edge="1" parent="1" source="n_xs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_ys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_skin_flag" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;" value="include skin effect ?" vertex="1">
