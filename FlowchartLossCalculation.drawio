        <mxCell id="n_yp_zero" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="y&lt;sub&gt;p&lt;/sub&gt; = 0" vertex="1">
          <mxGeometry height="30" width="80" x="80" y="915" as="geometry" />
        </mxCell>
        <mxCell id="e_prox_zero" edge="1" parent="1" source="n_prox_flag" style="rounded=0;" target="n_yp_zero">
