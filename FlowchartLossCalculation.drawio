        <mxCell id="n_l0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;" value="&lt;b&gt;λ₀ — Base eddy coupling (trefoil)&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;λ₀ = 3 · [m²/(1+m²)] · (d/(2s))²&lt;br&gt;C&lt;sub&gt;C0&lt;/sub&gt; = 3 for trefoil&lt;/font&gt;" vertex="1">
