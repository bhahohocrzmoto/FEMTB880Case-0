        <mxCell id="lbl_true2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=9;fontColor=#009900;" value="True" vertex="1">
          <mxGeometry height="15" width="40" x="314" y="965" as="geometry" />
        </mxCell>
        <mxCell id="n_rac" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD700;strokeColor=#D6B656;fontStyle=1;" value="def Rac_at_temp(self, T_cond_C)&lt;br&gt;R&lt;sub&gt;ac&lt;/sub&gt; = R&lt;sub&gt;dc&lt;/sub&gt;(θ) · (1 + y&lt;sub&gt;s&lt;/sub&gt; + y&lt;sub&gt;p&lt;/sub&gt;)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;IEC 60287-1-1:2023, Section 5.1.1&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="340" x="140" y="990" as="geometry" />
        </mxCell>
        <mxCell id="e_prox_rac" edge="1" parent="1" source="n_prox_flag" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_rac">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_wc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8C00;strokeColor=#D6B656;fontColor=#FFFFFF;fontStyle=1;" value="&lt;b&gt;W&lt;sub&gt;c&lt;/sub&gt; = I² · R&lt;sub&gt;ac&lt;/sub&gt;&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Conductor Joule loss [W/m] -&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: x-small;&quot;&gt;IEC 60287-1-1:2023 Section 5.1.1&lt;/span&gt;" vertex="1">
          <mxGeometry height="50" width="325" x="147.5" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="e_rac_wc" edge="1" parent="1" source="n_rac" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_wc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="diel_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#82B366;opacity=40;" value="" vertex="1">
          <mxGeometry height="530" width="380" x="610" y="270" as="geometry" />
        </mxCell>
        <mxCell id="diel_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=12;" value="DIELECTRIC LOSSES — W&lt;sub&gt;d&lt;/sub&gt;" vertex="1">
          <mxGeometry height="25" width="300" x="640" y="275" as="geometry" />
        </mxCell>
        <mxCell id="n_cap" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#82B366;" value="&lt;b&gt;Cable Capacitance — IEC 60287-1-1:2023 Section 5.2&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;C = 2π ε&lt;sub&gt;0&lt;/sub&gt; ε&lt;sub&gt;r&lt;/sub&gt; / ln(D&lt;sub&gt;i&lt;/sub&gt; / d&lt;sub&gt;c&lt;/sub&gt;)&lt;br&gt;d&lt;sub&gt;c&lt;/sub&gt; = d_inner_semicon = 33.3 mm (over conductor screen)&lt;br&gt;D&lt;sub&gt;i&lt;/sub&gt; = d_ins = 64.3 mm (over insulation)&lt;br&gt;ε&lt;sub&gt;r&lt;/sub&gt; = 2.5 (XLPE, IEC 60287-1-1 :&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: x-small;&quot;&gt;2023&amp;nbsp;&lt;/span&gt;&lt;font size=&quot;1&quot;&gt;&amp;nbsp;Table 3)&lt;/font&gt;" vertex="1">
          <mxGeometry height="95" width="350" x="625" y="315" as="geometry" />
        </mxCell>
        <mxCell id="n_u0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#82B366;" value="&lt;b&gt;Phase-to-earth voltage&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;U₀ = U_LL / √3 = 132 kV / √3 = 76.21 kV&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="280" x="660" y="435" as="geometry" />
        </mxCell>
        <mxCell id="e_cap_u0" edge="1" parent="1" source="n_cap" style="edgeStyle=orthogonalEdgeStyle;rounded=0;" target="n_u0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_wd_calc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#82B366;" value="&lt;b&gt;W&lt;sub&gt;d&lt;/sub&gt; — IEC 60287-1-1:2023 Section 5.2&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;W&lt;sub&gt;d&lt;/sub&gt; = ω · C · U₀² · tan(δ)&lt;br&gt;tan(δ) = 1.0×10⁻³ (XLPE, IEC 60287-1-1 : 2023 Table 3)&lt;br&gt;Note: W&lt;sub&gt;d&lt;/sub&gt; is independent of load current I and temperature&lt;/font&gt;" vertex="1">
          <mxGeometry height="75" width="340" x="630" y="505" as="geometry" />
        </mxCell>
        <mxCell id="e_u0_wd" edge="1" parent="1" source="n_u0" style="rounded=0;" target="n_wd_calc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="n_diel_flag" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;rounded=1;" value="include_dielectric&lt;br&gt;_losses ?&lt;br&gt;&lt;font size=&quot;1&quot;&gt;(TB 880 GP 7)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="170" x="715" y="615" as="geometry" />
        </mxCell>
        <mxCell id="e_wd_flag" edge="1" parent="1" source="n_wd_calc" style="rounded=0;" target="n_diel_flag">
