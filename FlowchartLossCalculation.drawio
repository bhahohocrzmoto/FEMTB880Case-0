        <mxCell id="n_input" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;T_core_C&lt;/b&gt; (conductor temperature °C)&lt;br&gt;&lt;b&gt;T_screen_C&lt;/b&gt; (sheath temperature °C)&lt;br&gt;&lt;b&gt;area_mode&lt;/b&gt; = &quot;analytical&quot; | &quot;fem&quot;" vertex="1">
