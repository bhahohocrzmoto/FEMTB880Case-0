        <mxCell id="n_input" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;T_core_C&lt;/b&gt; (conductor temperature °C)&lt;br&gt;&lt;b&gt;T_screen_C&lt;/b&gt; (sheath temperature °C)&lt;br&gt;&lt;b&gt;area_mode&lt;/b&gt; = &quot;analytical&quot; | &quot;fem&quot;&amp;nbsp;← affects R&lt;sub&gt;s&lt;/sub&gt;, β₁, λ₁″ (not only the final W/m³ conversion)" vertex="1">
          <mxGeometry height="60" width="520" x="582.5" y="170" as="geometry" />
