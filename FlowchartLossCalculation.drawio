        <mxCell id="circ_false" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=9;fontColor=#CC0000;" value="False: skip" vertex="1">
          <mxGeometry height="20" width="60" x="1190" y="660" as="geometry" />
